# Email (Resend) — sends ICS calendar invites to barbers and customers
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onlyclassicnoshit@hotmail.com
# Optional defaults until each barber sets their email in the admin dashboard
SPYROS_CALENDAR_EMAIL=
LAMBROS_CALENDAR_EMAIL=

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+357000000000

# Instagram Basic Display API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret (for reminder endpoints)
CRON_SECRET=your_cron_secret

# Barber admin dashboard (/dashboard) — one login per barber
SPYROS_ADMIN_PASSWORD=change_me_spyros
LAMBROS_ADMIN_PASSWORD=change_me_lambros
ADMIN_SESSION_SECRET=change_me_long_random_string
CUSTOMER_SESSION_SECRET=change_me_customer_session_secret
