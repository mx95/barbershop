# Email (Resend) — sends ICS invites to your shared booking calendar
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=onlyclassicnoshit@hotmail.com
# Inbox/calendar that receives every new, updated, or cancelled booking (.ics attachment)
BOOKING_CALENDAR_EMAIL=onlyclassicnoshit@hotmail.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+357000000000

# Instagram Basic Display API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret (for reminder endpoints)
CRON_SECRET=your_cron_secret
